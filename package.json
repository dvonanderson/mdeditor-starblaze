{
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "description": "Monorepo for MdEditor UIs and addons.",
  "license": "",
  "author": "ADIWG",
  "scripts": {
    "build": "pnpm build:ui:mdeditor",
    "build:ui:mdeditor": "pnpm run --filter mdeditor build",
    "lint": "concurrently \"pnpm:lint:*\" --names \"lint:\"",
    "lint:addons-core": "pnpm run --filter core lint",
    "lint:addons-md": "pnpm run --filter md lint",
    "lint:ui-mdeditor": "pnpm run --filter mdeditor lint",
    "test": "concurrently \"pnpm:test:*\" --names \"test:\"",
    "test:addons-core": "pnpm run --filter core test",
    "test:addons-md": "pnpm run --filter md test",
    "test:ui-mdeditor": "pnpm run --filter mdeditor test",
    "test-a11y": "concurrently \"pnpm:test-a11y:*\" --names \"test-a11y:\"",
    "test-a11y:mdeditor": "pnpm run --filter mdeditor test-a11y",
    "doc:toc": "doctoc README.md",
    "compliance:licenses": "pnpm licenses list",
    "compliance:audit": "pnpm audit --audit-level=moderate",
    "docs:dev": "vitepress dev docs/handbook",
    "docs:build": "vitepress build docs/handbook",
    "docs:preview": "vitepress preview docs/handbook",
    "prepare": "husky"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "doctoc": "^2.2.0",
    "ember-template-lint": "^6.0.0",
    "git-cz": "^4.9.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier-plugin-ember-template-tag": "^2.1.3",
    "vitepress": "^1.6.3"
  },
  "config": {
    "commitizen": {
      "path": "git-cz"
    }
  },
  "engines": {
    "node": "20.* || 22.*"
  }
}
