{
  "name": "core",
  "version": "0.0.0",
  "description": "The default blueprint for ember-cli addons.",
  "keywords": [
    "ember-addon"
  ],
  "repository": "",
  "license": "MIT",
  "author": "",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build:development": "ember build",
    "build": "ember build --environment=production",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\"",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "format": "concurrently \"npm:format:*\" --names \"format:\"",
    "format:js": "prettier --write '{addon,app,config,stories,tests}/**/*.js' *.js",
    "format:hbs": "prettier --write '{addon,app,tests}/**/*.hbs'",
    "start": "ember serve",
    "test": "ember test --test-port 0",
    "test:ember-compatibility": "ember try:each",
    "precommit": "pnpm lint && pnpm format && pnpm test",
    "doc:toc": "doctoc README.md"
  },
  "dependencies": {
    "@babel/core": "^7.26.10",
    "@formatjs/intl-durationformat": "^0.2.4",
    "ember-cli-babel": "^8.2.0",
    "ember-cli-htmlbars": "^6.3.0",
    "ember-auto-import": "^2.10.0",
    "ember-cli-sass": "^11.0.1",
    "ember-concurrency": "^4.0.3",
    "ember-intl": "^7.1.8",
    "ember-loading": "^2.0.0",
    "ember-template-imports": "^4.3.0",
    "ember-truth-helpers": "^4.0.3",
    "sass": "^1.69.5"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.26.10",
    "ember-eslint-parser": "*",
    "@babel/plugin-proposal-decorators": "^7.25.9",
    "@ember/optional-features": "^2.2.0",
    "@ember/test-helpers": "^5.1.0",
    "@embroider/macros": "^1.16.12",
    "@embroider/test-setup": "^4.0.0",
    "@eslint/js": "^9.23.0",
    "@glimmer/component": "^1.1.2",
    "@glimmer/tracking": "^1.1.2",
    "broccoli-asset-rev": "^3.0.0",
    "concurrently": "^9.1.2",
    "doctoc": "^2.2.0",
    "ember-cli": "~5.12.0",
    "ember-cli-dependency-checker": "^3.3.3",
    "ember-cli-deprecation-workflow": "^3.3.0",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-cli-sri": "^2.1.1",
    "ember-cli-terser": "^4.0.2",
    "ember-load-initializers": "^3.0.1",
    "ember-page-title": "^9.0.1",
    "ember-qunit": "^8.1.0",
    "ember-resolver": "^13.1.1",
    "ember-source": "~5.12.0",
    "ember-source-channel-url": "^3.0.0",
    "ember-template-lint": "^6.1.0",
    "ember-template-lint-plugin-prettier": "^5.0.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ember": "^12.7.5",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-qunit": "^8.2.6",
    "globals": "^15.15.0",
    "loader.js": "^4.7.0",
    "prettier": "^3.5.3",
    "prettier-plugin-ember-template-tag": "^2.0.4",
    "qunit": "^2.24.1",
    "qunit-dom": "^3.4.0",
    "webpack": "^5.98.0"
  },
  "peerDependencies": {
    "ember-source": ">= 4.0.0"
  },
  "engines": {
    "node": "20.* || 22.*"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "configPath": "tests/dummy/config"
  },
  "lint-staged": {
    "*.{js,gjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{hbs,gjs}": "ember-template-lint --fix",
    "*.{scss,yaml}": "prettier --write"
  }
}
